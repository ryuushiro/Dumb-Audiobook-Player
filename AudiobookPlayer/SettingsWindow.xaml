<Window x:Class="AudiobookPlayer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="450" Width="420" 
        Background="#121212" Foreground="White" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI, Tahoma, sans-serif">

    <Window.Resources>
        <!-- Reuse the dark button style -->
        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#282828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E3E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#181818"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsButtonStyle}">
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1ED760"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1AA34A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Library Section -->
            <RowDefinition Height="Auto"/>  <!-- Playback Section -->
            <RowDefinition Height="Auto"/>  <!-- System Section -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Action Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="⚙️ Settings" FontSize="28" FontWeight="Black" Margin="0,0,0,25"/>

        <!-- Library Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,25">
            <TextBlock Text="📂 LIBRARY FOLDER" FontSize="12" FontWeight="Bold" Foreground="#B3B3B3" Margin="0,0,0,10" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#282828" CornerRadius="8" Padding="12,10" Margin="0,0,10,0">
                    <TextBlock x:Name="LibraryPathText" Text="No folder selected" FontSize="13" Foreground="#B3B3B3" 
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </Border>
                <Button Grid.Column="1" Content="Browse..." Width="90" Height="40" 
                        Click="BrowseBtn_Click" Style="{StaticResource SettingsButtonStyle}"/>
            </Grid>
        </StackPanel>

        <!-- Playback Section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,25">
            <TextBlock Text="⏩ PLAYBACK" FontSize="12" FontWeight="Bold" Foreground="#B3B3B3" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Skip Duration:" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <ComboBox Style="{StaticResource DarkRoundedComboBox}" x:Name="SkipDurationComboBox" Width="120" Height="38" 
                          VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                          FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                          Background="#333333" Foreground="White" BorderThickness="0">
                    <ComboBoxItem Content="10 seconds" Tag="10"/>
                    <ComboBoxItem Content="15 seconds" Tag="15" IsSelected="True"/>
                    <ComboBoxItem Content="30 seconds" Tag="30"/>
                    <ComboBoxItem Content="60 seconds" Tag="60"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- System Section -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="💾 SYSTEM" FontSize="12" FontWeight="Bold" Foreground="#B3B3B3" Margin="0,0,0,10"/>
            <CheckBox x:Name="SavePositionCheckBox" Content="Save playback position on exit" IsChecked="True" 
                      Style="{StaticResource SettingsCheckBox}"/>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="100" Height="40" Margin="0,0,10,0" 
                    Click="CancelBtn_Click" Style="{StaticResource SettingsButtonStyle}"/>
            <Button Content="💾 Save" Width="120" Height="40" 
                    Click="SaveBtn_Click" Style="{StaticResource SaveButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
