<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Netflix-inspired Dark Red Theme -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1A0F0F" />
    <SolidColorBrush x:Key="WindowTextBrush" Color="White" />
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#E50914" />
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="White" />
    <SolidColorBrush x:Key="PrimaryAccentHoverBrush" Color="#F40612" />
    <SolidColorBrush x:Key="PrimaryAccentPressedBrush" Color="#B81D24" />
    
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#2B1515" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#421C1C" />
    <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="White" />
    
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#361717" />
    <SolidColorBrush x:Key="PanelHoverBrush" Color="#4D2222" />
    <SolidColorBrush x:Key="PanelPressedBrush" Color="#240D0D" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#421C1C" />
    
    <SolidColorBrush x:Key="MutedTextBrush" Color="#B3A1A1" />
    <SolidColorBrush x:Key="DropdownItemHoverBrush" Color="#5A2929" />
    
    <SolidColorBrush x:Key="LibraryItemBackgroundBrush" Color="#1C0F0F" />
</ResourceDictionary>
