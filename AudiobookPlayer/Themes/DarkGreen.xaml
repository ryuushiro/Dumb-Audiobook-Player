<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Spotify-inspired Dark Green Theme -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#121212" />
    <SolidColorBrush x:Key="WindowTextBrush" Color="White" />
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#1DB954" />
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="White" />
    <SolidColorBrush x:Key="PrimaryAccentHoverBrush" Color="#1ED760" />
    <SolidColorBrush x:Key="PrimaryAccentPressedBrush" Color="#1AA34A" />
    
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#282828" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#3E3E3E" />
    <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="White" />
    
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="PanelHoverBrush" Color="#444444" />
    <SolidColorBrush x:Key="PanelPressedBrush" Color="#222222" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#2A2A2A" />
    
    <SolidColorBrush x:Key="MutedTextBrush" Color="#B3B3B3" />
    <SolidColorBrush x:Key="DropdownItemHoverBrush" Color="#555555" />
    
    <SolidColorBrush x:Key="LibraryItemBackgroundBrush" Color="#1A1A1A" />
</ResourceDictionary>
