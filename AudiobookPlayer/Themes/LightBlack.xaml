<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Apple-inspired Light Black Theme -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F7" />
    <SolidColorBrush x:Key="WindowTextBrush" Color="#1D1D1F" />
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#1D1D1F" />
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="White" />
    <SolidColorBrush x:Key="PrimaryAccentHoverBrush" Color="#333336" />
    <SolidColorBrush x:Key="PrimaryAccentPressedBrush" Color="#000000" />
    
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#E8E8ED" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#D1D1D6" />
    <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="#1D1D1F" />
    
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelHoverBrush" Color="#F2F2F7" />
    <SolidColorBrush x:Key="PanelPressedBrush" Color="#E5E5EA" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#D1D1D6" />
    
    <SolidColorBrush x:Key="MutedTextBrush" Color="#86868B" />
    <SolidColorBrush x:Key="DropdownItemHoverBrush" Color="#D1D1D6" />
    
    <SolidColorBrush x:Key="LibraryItemBackgroundBrush" Color="#FFFFFF" />
</ResourceDictionary>
